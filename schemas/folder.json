{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Crossplane Folder Manifest Schema",
  "description": "JSON Schema for validating Crossplane Folder manifests (oss.grafana.crossplane.io/v1alpha1)",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "oss.grafana.crossplane.io/v1alpha1",
      "description": "API version for Grafana Folder resource"
    },
    "kind": {
      "type": "string",
      "const": "Folder",
      "description": "Resource kind"
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,61}[a-z0-9]$",
          "description": "Kubernetes resource name (lowercase DNS label format)",
          "minLength": 3,
          "maxLength": 63
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "properties": {
            "governance.grafana.io/tier": {
              "type": "string",
              "enum": ["ultra-rt", "real-time", "nrt", "standard", "degraded", "trend", "daily"],
              "description": "Alert routing tier this folder is associated with"
            }
          }
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "properties": {
            "org": {
              "type": "string",
              "description": "Parent organization resource name (K8s name of the Organization resource)"
            },
            "tier": {
              "type": "string",
              "enum": ["ultra-rt", "real-time", "nrt", "standard", "degraded", "trend", "daily"],
              "description": "Alert routing tier"
            }
          }
        }
      }
    },
    "spec": {
      "type": "object",
      "required": ["providerConfigRef", "forProvider"],
      "additionalProperties": false,
      "properties": {
        "providerConfigRef": {
          "type": "object",
          "required": ["name"],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            }
          }
        },
        "deletionPolicy": {
          "type": "string",
          "enum": ["Delete", "Orphan"],
          "default": "Delete"
        },
        "forProvider": {
          "type": "object",
          "required": ["title", "uid"],
          "additionalProperties": false,
          "properties": {
            "title": {
              "type": "string",
              "pattern": "^[A-Z]{2,6}\\/[A-Z][a-zA-Z0-9]+(\\/[A-Z][a-zA-Z0-9]+)*$",
              "description": "Folder title following naming convention (e.g., PLAT/RealTime)",
              "minLength": 5,
              "maxLength": 255
            },
            "uid": {
              "type": "string",
              "pattern": "^[a-z0-9-]{4,40}$",
              "description": "Folder UID (lowercase alphanumeric with hyphens)",
              "minLength": 4,
              "maxLength": 40
            },
            "orgId": {
              "type": "number",
              "description": "Grafana Organization ID"
            },
            "orgIdRef": {
              "type": "object",
              "required": ["name"],
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Reference to Organization resource name"
                }
              }
            },
            "parentFolderUid": {
              "type": "string",
              "description": "UID of parent folder for nested folder hierarchies"
            }
          }
        }
      }
    }
  },
  "x-governance-rules": {
    "tier_folder_mapping": {
      "ultra-rt": "UltraRealTime",
      "real-time": "RealTime",
      "nrt": "NearRealTime",
      "standard": "Standard",
      "degraded": "Degraded",
      "trend": "Trend",
      "daily": "Report"
    },
    "uid_must_be_unique": true,
    "title_must_follow_naming_convention": true
  }
}
